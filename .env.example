# ── Backend configuration ─────────────────────────────────────────────────────
# Copy this file to .env and fill in values. NEVER commit .env.

# API key sent by the Flutter app in X-API-Key header
DENTAL_API_KEY=change-me-to-a-secure-random-string

# Anthropic API key — obtain at console.anthropic.com
# Execute BAA before using with real patient data
ANTHROPIC_API_KEY=sk-ant-...

# Whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=base

# Whisper device: cuda | cpu
WHISPER_DEVICE=cuda

# Whisper compute type: float16 | int8_float16 | int8
WHISPER_COMPUTE_TYPE=float16

# Backend bind address and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8765

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
