# Dental Notes v2 Configuration
# Copy to .env and modify as needed. All values shown are defaults.

# Whisper model (small fits in 4GB VRAM with int8)
DENTAL_WHISPER_MODEL=small
DENTAL_COMPUTE_TYPE=int8

# Audio capture
DENTAL_SAMPLE_RATE=16000

# Voice Activity Detection threshold (0.0-1.0)
DENTAL_VAD_THRESHOLD=0.5

# Chunking parameters
DENTAL_MAX_CHUNK_DURATION_SECS=20
DENTAL_SILENCE_GAP_SECS=1.5
DENTAL_OVERLAP_SECS=1.0

# Transcript storage directory
DENTAL_STORAGE_DIR=./transcripts

# Server binding (127.0.0.1 = localhost only, PRV-01 compliance)
DENTAL_HOST=127.0.0.1
DENTAL_PORT=8000
